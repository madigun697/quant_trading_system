POSTGRES_DB=quant
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant
# Docker Compose runtime default
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Local uv override example:
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=55432
# MINIO_ENDPOINT=http://127.0.0.1:9000

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=us-east-1

ALPHAVANTAGE_API_KEY=replace_me
TIINGO_API_KEY=replace_me
FRED_API_KEY=replace_me
SEC_USER_AGENT=YourName your@email.com
DEFAULT_COHORT=us_liquidity_700_v1
UNIVERSE_BUFFER_COHORT=us_liquidity_900_buffer_v1
UNIVERSE_BUFFER_SIZE=900
UNIVERSE_TARGET_SIZE=700
SUPPORT_MARKET_SYMBOLS=SPY,VT,IEF,SGOV,JPST
LIQUIDITY_LOOKBACK_DAYS=60
LIQUIDITY_DISCOVERY_DAYS=90
TIINGO_HOURLY_REQUEST_BUDGET=50
TIINGO_MONTHLY_REQUEST_BUDGET=1000
TIINGO_DISCOVERY_BATCH_SIZE=200
YFINANCE_BATCH_SIZE=100
YFINANCE_TIMEOUT_SECONDS=30

AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=  # Generate with: openssl rand -base64 32
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
